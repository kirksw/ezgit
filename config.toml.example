# GitHub Token (optional, falls back to GITHUB_TOKEN env var)
[github]
# token = "ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Organizations to cache for faster access
[organizations]
orgs = [
    "facebook",
    "google",
    "kubernetes",
    "microsoft",
]

# Private repositories (owner/repo format)
[repos]
private = [
    "my-org/secret-repo",
    "company/internal",
]

# Git configuration
[git]
# Default directory for cloned repositories (optional)
clone_dir = "~/git/github.com"
# Clone as bare repo with worktree by default (optional, default: false)
# worktree = true
